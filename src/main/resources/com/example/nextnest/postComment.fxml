<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #272926;" stylesheets="@textf.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.nextnest.PostCommentController">
   <Button mnemonicParsing="false" onAction="#goToHome" prefHeight="33.0" prefWidth="82.0" style="-fx-background-color: #151928; -fx-border-color: a0a2ab;" text="&lt;&lt;Back" textFill="WHITE" />
    <Text style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">Comments</Text>

    <!-- VBox for displaying comments -->
    <VBox fx:id="commentVBox" spacing="5" style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-border-radius: 10; -fx-border-color: #dcdcdc; -fx-border-width: 1;">

        <!-- Comments will be dynamically added here -->
    </VBox>

    <!-- TextField for entering new comment -->
    <TextField fx:id="commentInputField" promptText="Enter your comment..." style="-fx-pref-width: 400px; -fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #ccc;" styleClass="transparent-text-field" />

    <!-- Button to submit the comment -->
    <Button fx:id="submitCommentButton" onAction="#submitComment" style="-fx-background-color: #151928; -fx-text-fill: white; -fx-border-radius: 25; -fx-padding: 8 16; -fx-border-color: a0a2ab;" text="Submit Comment" />
</VBox>
