<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="chatBox" prefHeight="276.0" prefWidth="349.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ChatController">
    <children>
        <!-- ScrollPane for the chat box -->
        <ScrollPane fitToHeight="true" fitToWidth="true">
            <content>
                <VBox fx:id="chatBox" spacing="5" />
            </content>
        </ScrollPane>

        <!-- Message Input and Send Button -->
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="messageInput" promptText="Type a message..." HBox.hgrow="ALWAYS" />
            <Button fx:id="sendButton" text="Send" />
        </HBox>
    </children>
</VBox>
